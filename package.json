{
  "name": "protokit",
  "publisher": "ach9948",
  "displayName": "ProtoKit",
  "description": "REST API and multi-protocol testing tool for VS Code",
  "version": "0.0.1",
  "license": "MIT",
  "keywords": [
    "rest",
    "api",
    "http",
    "websocket",
    "graphql",
    "client",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Undefined1228/protokit"
  },
  "bugs": {
    "url": "https://github.com/Undefined1228/protokit/issues"
  },
  "homepage": "https://github.com/Undefined1228/protokit#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "protokit",
          "title": "ProtoKit",
          "icon": "media/protokit.svg"
        }
      ]
    },
    "views": {
      "protokit": [
        {
          "id": "protokit.collections",
          "name": "컬렉션",
          "initialSize": 7
        },
        {
          "id": "protokit.history",
          "name": "히스토리",
          "initialSize": 3
        }
      ]
    },
    "commands": [
      {
        "command": "protokit.newRequest",
        "title": "새 요청",
        "category": "ProtoKit",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "protokit.newRequest",
          "when": "view == protokit.collections",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.0.0"
  }
}
