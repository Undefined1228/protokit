{
  "name": "protokit",
  "publisher": "ach9948",
  "displayName": "ProtoKit",
  "description": "REST API and multi-protocol testing tool for VS Code",
  "version": "0.3.0",
  "icon": "media/icon.png",
  "license": "MIT",
  "keywords": [
    "rest",
    "api",
    "http",
    "websocket",
    "graphql",
    "client",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Undefined1228/protokit"
  },
  "bugs": {
    "url": "https://github.com/Undefined1228/protokit/issues"
  },
  "homepage": "https://github.com/Undefined1228/protokit#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "protokit",
          "title": "ProtoKit",
          "icon": "media/protokit.svg"
        }
      ]
    },
    "views": {
      "protokit": [
        {
          "id": "protokit.collections",
          "name": "컬렉션",
          "initialSize": 7
        },
        {
          "id": "protokit.history",
          "name": "히스토리",
          "initialSize": 3
        }
      ]
    },
    "commands": [
      {
        "command": "protokit.newRequest",
        "title": "새 REST API 요청",
        "category": "ProtoKit",
        "icon": "$(add)"
      },
      {
        "command": "protokit.newWebSocket",
        "title": "새 WebSocket",
        "category": "ProtoKit",
        "icon": "$(broadcast)"
      },
      {
        "command": "protokit.newGraphQL",
        "title": "새 GraphQL",
        "category": "ProtoKit",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "protokit.newSSE",
        "title": "새 SSE",
        "category": "ProtoKit",
        "icon": "$(radio-tower)"
      },
      {
        "command": "protokit.newSocketIO",
        "title": "새 Socket.IO",
        "category": "ProtoKit",
        "icon": "$(plug)"
      },
      {
        "command": "protokit.newTCP",
        "title": "새 TCP",
        "category": "ProtoKit",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "protokit.newUDP",
        "title": "새 UDP",
        "category": "ProtoKit",
        "icon": "$(radio-tower)"
      },
      {
        "command": "protokit.newCollection",
        "title": "새 컬렉션",
        "category": "ProtoKit",
        "icon": "$(folder-opened)"
      },
      {
        "command": "protokit.renameCollection",
        "title": "이름 변경",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.deleteCollection",
        "title": "컬렉션 삭제",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.openSavedRequest",
        "title": "요청 열기",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.renameRequest",
        "title": "이름 변경",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.deleteRequest",
        "title": "요청 삭제",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.duplicateRequest",
        "title": "요청 복제",
        "category": "ProtoKit",
        "icon": "$(copy)"
      },
      {
        "command": "protokit.moveRequestUp",
        "title": "위로 이동",
        "category": "ProtoKit",
        "icon": "$(arrow-up)"
      },
      {
        "command": "protokit.moveRequestDown",
        "title": "아래로 이동",
        "category": "ProtoKit",
        "icon": "$(arrow-down)"
      },
      {
        "command": "protokit.manageEnvironments",
        "title": "환경변수 관리",
        "category": "ProtoKit",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "protokit.search",
        "title": "컬렉션 검색",
        "category": "ProtoKit",
        "icon": "$(search)"
      },
      {
        "command": "protokit.openHistoryEntry",
        "title": "히스토리 요청 열기",
        "category": "ProtoKit"
      },
      {
        "command": "protokit.clearHistory",
        "title": "히스토리 전체 삭제",
        "category": "ProtoKit",
        "icon": "$(clear-all)"
      },
      {
        "command": "protokit.runCollection",
        "title": "컬렉션 실행",
        "category": "ProtoKit",
        "icon": "$(play)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "protokit.collections",
        "contents": "ProtoKit에 오신 것을 환영합니다!\n\n컬렉션을 만들어 API 요청을 관리하세요.\n[새 컬렉션 만들기](command:protokit.newCollection)"
      },
      {
        "view": "protokit.history",
        "contents": "요청을 보내면 기록이 여기에 표시됩니다."
      }
    ],
    "submenus": [
      {
        "id": "protokit.newConnectionMenu",
        "label": "새 연결",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "submenu": "protokit.newConnectionMenu",
          "when": "view == protokit.collections",
          "group": "navigation@5"
        },
        {
          "command": "protokit.newCollection",
          "when": "view == protokit.collections",
          "group": "navigation@4"
        },
        {
          "command": "protokit.search",
          "when": "view == protokit.collections",
          "group": "navigation@1"
        },
        {
          "command": "protokit.clearHistory",
          "when": "view == protokit.history",
          "group": "navigation"
        }
      ],
      "protokit.newConnectionMenu": [
        {
          "command": "protokit.newRequest",
          "group": "1@1"
        },
        {
          "command": "protokit.newWebSocket",
          "group": "1@2"
        },
        {
          "command": "protokit.newGraphQL",
          "group": "1@3"
        },
        {
          "command": "protokit.newSSE",
          "group": "1@4"
        },
        {
          "command": "protokit.newSocketIO",
          "group": "1@5"
        },
        {
          "command": "protokit.newTCP",
          "group": "1@6"
        },
        {
          "command": "protokit.newUDP",
          "group": "1@7"
        }
      ],
      "view/item/context": [
        {
          "command": "protokit.runCollection",
          "when": "view == protokit.collections && viewItem == collection",
          "group": "0_run@1"
        },
        {
          "command": "protokit.manageEnvironments",
          "when": "view == protokit.collections && viewItem == collection",
          "group": "0_run@2"
        },
        {
          "command": "protokit.renameCollection",
          "when": "view == protokit.collections && viewItem == collection",
          "group": "1_modify@1"
        },
        {
          "command": "protokit.deleteCollection",
          "when": "view == protokit.collections && viewItem == collection",
          "group": "1_modify@2"
        },
        {
          "command": "protokit.renameRequest",
          "when": "view == protokit.collections && viewItem == request",
          "group": "1_modify@1"
        },
        {
          "command": "protokit.duplicateRequest",
          "when": "view == protokit.collections && viewItem == request",
          "group": "1_modify@2"
        },
        {
          "command": "protokit.moveRequestUp",
          "when": "view == protokit.collections && viewItem == request",
          "group": "2_order@1"
        },
        {
          "command": "protokit.moveRequestDown",
          "when": "view == protokit.collections && viewItem == request",
          "group": "2_order@2"
        },
        {
          "command": "protokit.deleteRequest",
          "when": "view == protokit.collections && viewItem == request",
          "group": "3_delete@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.23.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.20.0"
  }
}
